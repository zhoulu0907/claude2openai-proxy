# ============================================
# claude2openai-proxy 配置文件
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ============================================

# --------------------------------------------
# OpenAI API 配置（必需）
# --------------------------------------------
# OpenAI API 密钥（或通过 X-API-Key 请求头动态传递）
OPENAI_API_KEY=""

# OpenAI API 基础 URL（兼容 OpenAI 格式的后端服务）
# 示例：https://api.openai.com/v1
#       http://localhost:4000/v1  (LiteLLM Proxy)
#       https://your-provider.com/v1
OPENAI_API_BASE="https://api.openai.com/v1"

# --------------------------------------------
# 模型配置（必需）
# --------------------------------------------
# 大模型（用于复杂任务、代码生成等）
BIG_MODEL="gpt-4.1"

# 小模型（用于快速响应、简单任务）
SMALL_MODEL="gpt-4.1-mini"

# 最大输出 token 数
MAX_TOKENS="65535"

# --------------------------------------------
# 模型路由配置（可选）
# --------------------------------------------
# 根据模型名称前缀自动路由到大/小模型
# 逗号分隔，不区分大小写
# 示例：opus,sonnet → 使用 BIG_MODEL
#       haiku → 使用 SMALL_MODEL
BIG_PREFIXES="opus,sonnet"
SMALL_PREFIXES="haiku"

# --------------------------------------------
# 服务配置（可选）
# --------------------------------------------
# 外部访问基础 URL（用于 OpenAPI 文档中的服务器地址）
# 示例：https://your-domain.com/claude/
# 留空则使用相对路径
BASE_URL=""

# 服务监听端口（Docker 运行时使用）
PORT="8082"

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="WARNING"
